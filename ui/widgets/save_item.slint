// ==========================================================================
// PCL-rs 存档行 —— 1:1 移植 PCL-CE 存档管理页的世界/存档项
//   原版文件：Pages/PageInstance/PageInstanceSaves.xaml.cs（LoadDefault 内 worldItem 构建）
//
// 结构（原版 MyListItem, Type=Clickable, Height=42）：
//   位图 Logo（存档 icon.png 缓存副本；无图标 = NoIcon.png，由 Rust 侧提供）；
//   Title = 存档文件夹名；Info = "创建于 X  |  最后修改于 Y"（Rust 侧拼好）；
//   右侧 25×25 MyIconButton（悬停淡入）：
//     folder-open 打开、trash-2 删除、copy 复制（路径进剪贴板）、info 详情，
//     若开启快速进入存档功能则追加 play 快速进入；
//   点击 → 进入该存档的资源管理页。
//   删除中状态：worldItem.IsEnabled = false + Info 替换为"正在删除…"（Info 由宿主改）。
//
// 已知偏差：
//   1. ToolTip（打开/删除/复制/详情/快速进入）未移植；
//   2. 删除中的 Info 文案替换由宿主负责（本部件仅按 data.deleting 禁用整行）。
// ==========================================================================

import { GlobalTheme } from "../theme/theme.slint";
import { MyIconButton } from "../components/icon_button.slint";
import { ListRowBase } from "row_base.slint";

// 存档行数据
export struct SaveItemData {
    icon: image,            // 存档 icon.png / NoIcon.png
    name: string,           // 存档文件夹名
    info: string,           // "创建于 X  |  最后修改于 Y"（删除中 = "正在删除…"）
    deleting: bool,         // 删除中（整行禁用）
}

export component SaveItem {
    in property <SaveItemData> data;
    in property <bool> quick-play: false;   // 是否显示快速进入（play）按钮

    callback clicked();            // 点击（进入存档资源管理页）
    callback open-clicked();       // 打开存档文件夹
    callback delete-clicked();     // 删除存档
    callback copy-clicked();       // 复制存档路径到剪贴板
    callback info-clicked();       // 存档详情
    callback launch-clicked();     // 快速进入存档（quick-play 时有效）

    row := ListRowBase {
        width: 100%;
        icon: root.data.icon;
        title: root.data.name;
        info: root.data.info;
        enabled: !root.data.deleting;
        trailing-buttons: root.quick-play ? 5 : 4;
        clicked => { root.clicked(); }

        // 打开（folder-open）
        MyIconButton {
            self-width: 25px; self-height: 25px;
            icon: @image-url("../assets/icons/lucide/folder-open.svg");
            clicked => { root.open-clicked(); }
        }
        // 删除（trash-2）
        MyIconButton {
            self-width: 25px; self-height: 25px;
            icon: @image-url("../assets/icons/lucide/trash-2.svg");
            clicked => { root.delete-clicked(); }
        }
        // 复制（copy）
        MyIconButton {
            self-width: 25px; self-height: 25px;
            icon: @image-url("../assets/icons/lucide/copy.svg");
            clicked => { root.copy-clicked(); }
        }
        // 详情（info）
        MyIconButton {
            self-width: 25px; self-height: 25px;
            icon: @image-url("../assets/icons/lucide/info.svg");
            clicked => { root.info-clicked(); }
        }
        // 快速进入（play，仅 quick-play）
        if root.quick-play : MyIconButton {
            self-width: 25px; self-height: 25px;
            icon: @image-url("../assets/icons/lucide/play.svg");
            clicked => { root.launch-clicked(); }
        }
    }
}
