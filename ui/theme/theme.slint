// PCL-CE 1:1 theme palette (default light theme "SkyBlue").
// ColorBrush1..8 mirror Application.xaml of the original project:
//   1 #343d4a main text/border   2 #0b5bcb strong accent
//   3 #1370f3 primary accent     4 #4890f5 hover accent
//   5 #96c0f9 Bg0 border         6 #d5e6fd press bg
//   7 #e0eafd hover bg           8 #eaf2fe lightest bg
export global GlobalTheme {
    in-out property<brush> window-background: #fbfbfb;
    in-out property<brush> left-panel-background: #d2fbfbfb;

    in-out property<brush> background: #deecff;

    in-out property<brush> combo-box-background: #f4f9fc;
    in-out property<brush> combo-box-background-hover: #e1ecfa;

    in-out property<brush> card-border-color: #bcdcf8;
    in-out property<brush> card-border-color-hover: #bbd4f9;
    in-out property<brush> card-background: #f6f9fb;
    in-out property<brush> card-background-hover: #edf3fb;

    in-out property<brush> button-border-red: #ce2111;
    in-out property<brush> button-border-red-hover: #ff4c4c;
    in-out property<brush> button-border-highlight: #1762b6;
    in-out property<brush> button-border-hover: #2078da;
    in-out property<brush> button-border-normal: #323b47;
    in-out property<brush> button-border-disabled: #8f8f8f;

    in-out property<brush> button-background: #f9fbfc;
    in-out property<brush> button-background-hover: #e6f2ff;
    in-out property<brush> button-background-red-hover: #f6e9e9;
    in-out property<brush> button-background-disabled: #f7fafc;

    in-out property<brush> checkbox-border-unchecked: #343d4a;
    in-out property<brush> checkbox-border-checked:   #0b5bcb;
    in-out property<brush> checkbox-border-hover:     #1370f3;
    in-out property<brush> checkbox-border-disabled:  #a6a6a6;
    in-out property<brush> checkbox-background:       #f7f9fc;
    in-out property<brush> checkbox-background-pressed: #bee0eafd;
    in-out property<brush> checkbox-indeterminate-block: #1762b6;
    
    in-out property<brush> primary-text-color: #1762b6;
    in-out property<brush> secondary-text-color: #343d4a;

    in-out property<length> font-size: 13px;
    in-out property<int> title-font-weight: 700;
    in-out property<string> font-family: "Microsoft YaHei UI";

    in-out property<length> border-width: 1px;
    in-out property<length> corner-radius: 4px;
}