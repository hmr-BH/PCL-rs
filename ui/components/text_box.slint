// ==========================================================================
// PCL-rs 单行文本输入框 MyTextBox — 1:1 移植
// 原版文件：
//   Controls/MyTextBox.cs
//   Application.xaml 中 <Style TargetType="local:MyTextBox">（约 309~363 行）
// 关键参数（原版）：
//   高度 MinHeight 28px，圆角 CornerRadius=3，边框 1px，字号 13
//   常态：边框 ColorBrushBg0 / 背景 ColorBrushHalfWhite（100ms）
//   悬停：边框 ColorBrush4 / 背景 ColorBrush7（100ms）
//   聚焦：边框 ColorBrush3 / 背景 ColorBrush7（10ms）
//   验证失败（用户输入过后）：ColorBrushRedLight / ColorBrushRedBack（200ms）
//   禁用：ColorBrushGray5 / ColorBrushGray6（200ms），文字 Gray1→Gray4（200ms）
//   错误行 labWrong：高 0→21px + 透明度 0→1，150ms EaseOutFluent，
//     Padding 0,4,0,0，颜色跟随 BorderBrush（失败时为 RedLight）
//   水印 labHint：Gray4，与文字同位（边框 1 + 宿主 5 + TextView 2 = 8px）
//   选区刷 SelectionBrush=ColorBrush3（WPF 默认 SelectionOpacity 0.4）
// 已知偏差：
//   1. 原版 MyTextBox 自身没有清除按钮（清除按钮属于 MySearchBox），故无。
//   2. 密码模式用 TextInput input-type:password 实现（原版为相同样式的
//      PasswordBox，颜色规则一致）。
//   3. 文本超长横向滚动由 cursor-position-changed 手动驱动（WPF 自动滚动）。
//   4. 错误行 Margin 0,0,0,-3 的 -3px 回吸未复刻（视觉差异可忽略）。
//   5. max-length 在输入后回退到上一有效文本（WPF 在输入前拦截），
//      超长瞬间光标跳到末尾。
// ==========================================================================

import { GlobalTheme } from "../theme/theme.slint";

export component MyTextBox {
    in property <string> hint-text: "";              // 水印提示文本
    in-out property <string> text: "";               // 文本（双向绑定）
    in property <bool> enabled: true;
    in property <bool> password: false;              // 密码模式（原版 PasswordBox）
    in property <bool> has-background: true;         // 原版 HasBackground
    in property <bool> show-validate-result: true;   // 原版 ShowValidateResult
    in property <string> validate-result: "";        // 验证结果，空串=通过
    out property <bool> is-validated: root.validate-result == "";
    out property <bool> has-focus: input.has-focus;
    out property <bool> has-hover: touch.has-hover;
    in property <length> corner-radius: 3px;
    in property <length> box-height: 28px;
    in property <length> border-width: 1px;
    in property <length> content-padding-left: 0px;  // 原版 Padding 左（搜索框用 32）
    in property <length> content-padding-right: 0px; // 原版 Padding 右（搜索框用 40）
    in property <length> font-size: GlobalTheme.font-size;
    in property <int> max-length: 1000;              // 原版 MaxLength=1000

    callback edited(string);                         // 用户编辑（未超长时触发）
    callback accepted();                             // 回车（原版 Enter → RaiseCustomEvent）
    callback validate-changed();                     // 原版 ValidateChanged

    // 注：内置 focus()/clear-focus() 经 forward-focus 转发至内部 TextInput
    // 原版 ForceShowAsSuccess：强制按“尚未输入过”显示，不影响实际验证结果
    public function force-show-as-success() { root.is-text-changed = false; }

    // 是否已经由用户输入过文本（原版 isTextChanged：未输入前不显示验证失败）
    private property <bool> is-text-changed: false;
    private property <bool> invalid-shown: !root.is-validated && root.is-text-changed;
    private property <bool> show-wrong: root.show-validate-result && root.invalid-shown;

    // ---- 颜色（原版 RefreshColor，动画时长取目标状态时长） ----
    property <brush> border-color: {
        if !root.enabled { GlobalTheme.gray5 }
        else if root.invalid-shown { GlobalTheme.red-light }
        else if input.has-focus { GlobalTheme.color3 }
        else if touch.has-hover { GlobalTheme.color4 }
        else { GlobalTheme.color-bg0 }
    };
    property <brush> back-color: {
        if !root.has-background { Colors.transparent }
        else if !root.enabled { GlobalTheme.gray6 }
        else if root.invalid-shown { GlobalTheme.red-back }
        else if input.has-focus || touch.has-hover { GlobalTheme.color7 }
        else { GlobalTheme.color-half-white }
    };
    property <brush> text-color: root.enabled ? GlobalTheme.gray1 : GlobalTheme.gray4;
    // 状态动画时长（原版：聚焦 10ms / 悬停·常态 100ms / 失败·禁用 200ms）。
    // 注意：必须内联写在 animate 的 duration 里——若提取为自定义属性，
    // 在 enabled:false 实例中会被常量折叠并移除，触发 Slint 编译器
    // remove_unused 内部 panic（已实测）。

    // ---- 超长截断（MaxLength）：回退到上一个有效文本 ----
    private property <string> prev-text: "";
    private property <bool> truncating: false;
    changed text => {
        if root.truncating { return; }
        if root.text.character-count > root.max-length {
            root.truncating = true;
            root.text = root.prev-text;
            root.truncating = false;
        } else {
            root.prev-text = root.text;
        }
    }

    changed validate-result => { root.validate-changed(); }

    forward-focus: input;
    height: root.box-height + (root.show-wrong ? 21px : 0px);
    animate height { duration: 150ms; }              // EaseOutFluent ≈ 默认缓动

    // ===== 输入行（边框 + 背景 + 文本宿主） =====
    bg := Rectangle {
        x: 0; y: 0;
        width: 100%; height: root.box-height;
        border-radius: root.corner-radius;
        border-width: root.border-width;
        border-color: root.border-color;
        background: root.back-color;
        animate border-color { duration: input.has-focus ? (root.invalid-shown ? 200ms : 10ms) : (touch.has-hover ? (root.invalid-shown ? 200ms : 100ms) : (root.invalid-shown || !root.enabled ? 200ms : 100ms)); }
        animate background { duration: input.has-focus ? (root.invalid-shown ? 200ms : 10ms) : (touch.has-hover ? (root.invalid-shown ? 200ms : 100ms) : (root.invalid-shown || !root.enabled ? 200ms : 100ms)); }

        touch := TouchArea {
            width: 100%; height: 100%;
            enabled: root.enabled;
            mouse-cursor: MouseCursor.text;
            clicked => { input.focus(); }
        }

        // 文本裁剪区（原版 ScrollViewer Margin 5,0,0,0 + TextView 2px + 边框）
        clip-rect := Rectangle {
            x: root.border-width + 5px + root.content-padding-left + 2px;
            width: max(0px, parent.width - self.x - root.border-width - root.content-padding-right);
            height: 100%;
            clip: true;

            input := TextInput {
                property <length> scroll-x: 0px;
                x: clip-rect.width >= self.preferred-width ? 0px : min(0px, self.scroll-x);
                y: 0;
                width: max(clip-rect.width, self.preferred-width + 4px);
                height: 100%;
                text <=> root.text;
                font-size: root.font-size;
                font-family: GlobalTheme.font-family;
                color: root.text-color;
                animate color { duration: 200ms; }
                vertical-alignment: center;
                horizontal-alignment: left;
                single-line: true;
                input-type: root.password ? InputType.password : InputType.text;
                enabled: root.enabled;
                // 原版 SelectionBrush=ColorBrush3 + WPF 默认 SelectionOpacity 0.4
                selection-background-color: GlobalTheme.color3.with-alpha(0.4);

                cursor-position-changed(pos) => {
                    // 光标越出可视区时手动横滚（WPF 由 ScrollViewer 自动完成）
                    if pos.x + self.scroll-x < 0px {
                        self.scroll-x = -pos.x;
                    } else if pos.x + self.scroll-x > clip-rect.width - 2px {
                        self.scroll-x = clip-rect.width - 2px - pos.x;
                    }
                }
                edited => {
                    if self.text.character-count <= root.max-length {
                        root.is-text-changed = true;
                        root.edited(self.text);
                    }
                }
                accepted => { root.accepted(); }
            }
        }

        // 水印 labHint（仅文本为空时显示，与文字同位）
        if root.text == "" : Text {
            x: clip-rect.x;
            width: clip-rect.width;
            height: root.box-height;
            text: root.hint-text;
            color: GlobalTheme.gray4;
            font-size: root.font-size;
            font-family: GlobalTheme.font-family;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    // ===== 错误行 labWrong（高 0→21 + 淡入，150ms） =====
    wrong := Text {
        x: 0px;
        y: root.box-height + 4px;                    // Padding 0,4,0,0
        width: 100%;
        height: 17px;
        text: root.validate-result;
        color: root.border-color;                    // 原版 Foreground=BorderBrush
        animate color { duration: input.has-focus ? (root.invalid-shown ? 200ms : 10ms) : (touch.has-hover ? (root.invalid-shown ? 200ms : 100ms) : (root.invalid-shown || !root.enabled ? 200ms : 100ms)); }
        font-size: GlobalTheme.font-size;
        font-family: GlobalTheme.font-family;
        vertical-alignment: top;
        opacity: root.show-wrong ? 1 : 0;
        visible: self.opacity > 0;
        animate opacity { duration: 150ms; }
    }
}
